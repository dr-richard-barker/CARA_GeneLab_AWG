    title: "CARA — Arabidopsis root-tip spaceflight RNA-seq"
    notes: "NASA OSDR OSD-120 / GLDS-120"
    url: "https://osdr.nasa.gov/bio/repo/data/studies/OSD-120"
  - type: software
    title: "Virtual Root — open auxin-transport model"
    url: "https://github.com/dr-richard-barker/virtual-root"
